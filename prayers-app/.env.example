# ─── Backend API ────────────────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:8000

# ─── Stripe ─────────────────────────────────────────────────
# מפתח פומבי בלבד (pk_) — לעולם אל תכניס כאן את המפתח הסודי!
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXX

# ─── Firebase ───────────────────────────────────────────────
EXPO_PUBLIC_FIREBASE_API_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXXX
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
EXPO_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:XXXXXXXXXXXXXXXX

# ─── Google Sign-In ─────────────────────────────────────────
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=XXXXXXXXXXXXXX.apps.googleusercontent.com
